# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

POSTGRES_HOST_PORT=15432
MINIO_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
REDIS_HOST_PORT=16379
BACKEND_HOST_PORT=3101

DATABASE_URL="postgresql://postgres:123456@localhost:15432/admin_system"

# 应用端口
PORT=3101
APP_HOST=localhost

# JWT 配置
JWT_SECRET=your_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=*

# Swagger 配置
SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs

# MinIO 配置
MINIO_ENDPOINT=localhost
MINIO_PORT=19000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=12345678
MINIO_USE_SSL=false

# 不同业务模块的桶配置
MINIO_BUCKET_USER_AVATAR=user-avatars
MINIO_BUCKET_PRODUCT=product-images
MINIO_BUCKET_DOCUMENT=documents
MINIO_BUCKET_ARCHIVE=archives
MINIO_BUCKET_COMMON=common-files

# Redis 配置
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=123456
REDIS_DB=0
REDIS_TTL=3600000
