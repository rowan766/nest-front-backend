POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=15432
BACKEND_BIND_HOST=127.0.0.1
BACKEND_HOST_PORT=3101
POSTGRES_DATA_DIR=/srv/zenoly-data/cow/postgres

DATABASE_URL="postgresql://postgres:123456@postgres:5432/admin_system"

# 应用端口
PORT=3001
APP_HOST=0.0.0.0

# 域名 / 跨域
SERVER_HOST=cow.zenoly.cn
CORS_ORIGIN=https://cow.zenoly.cn

# JWT 配置
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Swagger 配置
SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs

# MinIO 配置
# 这里复用宿主机上已经运行的 nestjs-project1-minio，通过宿主机端口访问
MINIO_ENDPOINT=host.docker.internal
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=12345678
MINIO_USE_SSL=false

# 不同业务模块的桶配置
MINIO_BUCKET_USER_AVATAR=user-avatars
MINIO_BUCKET_PRODUCT=product-images
MINIO_BUCKET_DOCUMENT=documents
MINIO_BUCKET_ARCHIVE=archives
MINIO_BUCKET_COMMON=common-files

# Redis 配置
# 这里复用宿主机上已经运行的 nestjs-project1-redis，通过宿主机端口访问
REDIS_ENABLED=true
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0
REDIS_TTL=3600000
